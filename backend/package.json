{
  "name": "gridwatch-backend",
  "version": "1.0.0",
  "description": "GridWatch Backend",
  "main": "dist/index.js",
  "scripts": {
    "start": "npx prisma generate && npx prisma db push --accept-data-loss && node dist/seed.js && node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "prisma": "^6.19.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
